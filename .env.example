# Devin API (org-scoped v3). The key may be stored with or without the cog_ prefix;
# config.py normalizes it to `cog_<key>` automatically.
orgId=org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
cogKey=your_devin_service_user_key

# GitHub — token needs `repo` scope (create issues, comment, manage webhook).
# Locally you can use: gh auth token
githubToken=ghp_or_gho_xxx
githubRepo=YourOrg/superset

# Automation behavior
triggerLabel=devin-fix
webhookSecret=generate_with_openssl_rand_hex_24
maxAcuLimit=10
pollIntervalSeconds=20
reconcileIntervalSeconds=30
